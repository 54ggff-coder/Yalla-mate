{
  "entities": {
    "Message": {
      "title": "Message",
      "description": "Global user and system notification messages",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "sender": { "type": "string" },
        "senderId": { "type": "string" },
        "timestamp": { "type": "string" },
        "avatar": { "type": "string" },
        "isSystem": { "type": "boolean" }
      },
      "required": ["text", "sender", "senderId"]
    },
    "CommunityMessage": {
      "title": "CommunityMessage",
      "description": "Messages posted inside specific interest-based communities",
      "type": "object",
      "properties": {
        "communityId": { "type": "string" },
        "text": { "type": "string" },
        "sender": { "type": "string" },
        "senderId": { "type": "string" },
        "timestamp": { "type": "string" },
        "avatar": { "type": "string" }
      },
      "required": ["communityId", "text", "sender", "senderId"]
    },
    "IncidentReport": {
      "title": "IncidentReport",
      "description": "Crowdsourced incident/emergency reports for user safety",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "severity": { "type": "string" },
        "location": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "reportedBy": { "type": "string" },
        "reporterId": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["title", "description", "category", "severity", "reporterId"]
    },
    "FriendRequest": {
      "title": "FriendRequest",
      "description": "Pending and accepted friendship invitations",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "declined", "blocked"] },
        "timestamp": { "type": "string" }
      },
      "required": ["senderId", "receiverId", "status"]
    },
    "Follow": {
      "title": "Follow",
      "description": "One-way following relationship between users",
      "type": "object",
      "properties": {
        "followerId": { "type": "string" },
        "followingId": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["followerId", "followingId"]
    },
    "Chat": {
      "title": "Chat",
      "description": "Private or group chat session",
      "type": "object",
      "properties": {
        "participants": { "type": "array" },
        "type": { "type": "string", "enum": ["private", "group"] },
        "name": { "type": "string" },
        "avatar": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string" },
        "lastMessage": { "type": "string" },
        "lastTimestamp": { "type": "string" },
        "admins": { "type": "array" }
      },
      "required": ["participants", "type"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Message within a Chat session",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "image", "video", "location", "file", "voice"] },
        "mediaUrl": { "type": "string" },
        "location": { "type": "object" },
        "timestamp": { "type": "string" },
        "readBy": { "type": "array" },
        "replyTo": { "type": "string" },
        "edited": { "type": "boolean" }
      },
      "required": ["chatId", "senderId", "type"]
    },
    "Post": {
      "title": "Post",
      "description": "User shared posts or reels",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "content": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "mediaType": { "type": "string", "enum": ["image", "video"] },
        "isReel": { "type": "boolean" },
        "timestamp": { "type": "string" },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" },
        "location": { "type": "string" },
        "hashtags": { "type": "array" }
      },
      "required": ["authorId"]
    },
    "Comment": {
      "title": "Comment",
      "description": "Comment on a Post",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "authorId": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["postId", "authorId", "text"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User-specific notifications",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "fromId": { "type": "string" },
        "text": { "type": "string" },
        "read": { "type": "boolean" },
        "timestamp": { "type": "string" },
        "data": { "type": "object" }
      },
      "required": ["userId", "type", "text"]
    }
  },
  "firestore": {
    "messages": {
      "schema": "Message",
      "description": "Collection of platform-wide messages"
    },
    "community_messages": {
      "schema": "CommunityMessage",
      "description": "Collection of community chat lounge discussions"
    },
    "incident_reports": {
      "schema": "IncidentReport",
      "description": "Public crowd-sourced alerts and emergency updates"
    },
    "friend_requests": {
      "schema": "FriendRequest",
      "description": "Social invitations"
    },
    "follows": {
      "schema": "Follow",
      "description": "User following relationships"
    },
    "chats": {
      "schema": "Chat",
      "description": "Chat sessions"
    },
    "chat_messages": {
      "schema": "ChatMessage",
      "description": "Messages in chats"
    },
    "posts": {
      "schema": "Post",
      "description": "Social feed content"
    },
    "comments": {
      "schema": "Comment",
      "description": "Post comments"
    },
    "outings": {
      "description": "Outings created by users"
    },
    "reels_likes": {
      "description": "Likes on Reels"
    },
    "notifications": {
      "schema": "Notification",
      "description": "User notifications"
    }
  }
}
